<%- include('layout', { title }) %>

<section class="container tool-section">
  <h1><%= tool.name %></h1>
  <p><%= tool.description %></p>

  <% if (typeof error !== 'undefined' && error) { %>
    <p class="alert alert-error"><%= error %></p>
  <% } %>

  <% if (typeof result !== 'undefined' && result) { %>
    <div class="alert alert-success">
      <p>Your file was processed successfully using your <strong><%= result.usageType %></strong> access.</p>
      <p>Output file: <code><%= result.fileName %></code></p>
      <a class="btn btn-primary btn-sm" href="/<%= tool.slug %>/download/<%= result.fileName %>" download>Download File</a>
    </div>
  <% } %>

  <% if (tool.available === false) { %>
    <p class="alert alert-error">This tool isn't available yet — we're working on adding it soon. In the meantime, check out our other PDF tools.</p>
  <% } else { %>
    <form method="POST" action="/<%= tool.slug %>/process" enctype="multipart/form-data" class="upload-form">
      <label for="file"><%= tool.multiFile ? 'Choose files' : 'Choose a file' %></label>
      <input
        type="file"
        id="file"
        name="file"
        accept="<%= tool.accept || 'application/pdf' %>"
        <%= tool.multiFile ? 'multiple' : '' %>
        required
      />

      <% if (tool.formField) { %>
        <label for="<%= tool.formField.name %>"><%= tool.formField.label %></label>
        <% if (tool.formField.type === 'select') { %>
          <select id="<%= tool.formField.name %>" name="<%= tool.formField.name %>">
            <% tool.formField.options.forEach(function(opt) { %>
              <option value="<%= opt[0] %>"><%= opt[1] %></option>
            <% }); %>
          </select>
        <% } else { %>
          <input
            type="text"
            id="<%= tool.formField.name %>"
            name="<%= tool.formField.name %>"
            placeholder="<%= tool.formField.placeholder || '' %>"
          />
        <% } %>
      <% } %>

      <button type="submit" class="btn btn-primary">Process File</button>
    </form>
  <% } %>

  <p class="tool-note">Your first 7 tool uses are free. After that, start a <a href="/trial">3-day free trial</a> or <a href="/pricing">subscribe</a> for unlimited access.</p>
</section>

<%- include('partials/footer') %>
