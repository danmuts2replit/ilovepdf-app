<%- include('layout', { title }) %>

<% const icon = getToolIcon(tool.slug); %>
<section class="container tool-section">
  <div class="tool-header">
    <div class="tool-icon" style="background: <%= icon.color %>1a; color: <%= icon.color %>;">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><%- icon.paths %></svg>
    </div>
    <h1><%= tool.name %></h1>
  </div>
  <p><%= tool.description %></p>

  <% if (typeof error !== 'undefined' && error) { %>
    <p class="alert alert-error"><%= error %></p>
  <% } %>

  <% if (typeof result !== 'undefined' && result) { %>
    <div class="alert alert-success">
      <p>Your file was processed successfully using your <strong><%= result.usageType %></strong> access.</p>
      <p>Output file: <code><%= result.fileName %></code></p>
    </div>
  <% } %>

  <form method="POST" action="/tools/<%= tool.slug %>/process" enctype="multipart/form-data" class="upload-form">
    <label for="file">Choose a PDF file</label>
    <input type="file" id="file" name="file" accept="application/pdf" required />
    <button type="submit" class="btn btn-primary">Process File</button>
  </form>

  <p class="tool-note">First use is free. After that, start a <a href="/trial">3-day free trial</a> or <a href="/pricing">subscribe</a> for unlimited access.</p>
</section>

<%- include('partials/footer') %>
