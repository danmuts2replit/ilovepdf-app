# Server
PORT=3000
NODE_ENV=development
APP_URL=https://app.ilovepdf.shop
MAIN_SITE_URL=https://ilovepdf.shop

# Session
SESSION_SECRET=

# Database (MySQL - e.g. Hostinger)
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=

# Paystack
PAYSTACK_MODE=test
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_CALLBACK_URL=https://app.ilovepdf.shop/payment/callback
PAYSTACK_WEBHOOK_SECRET=
# Must match a currency enabled on your Paystack account (check Paystack dashboard
# settings if you see "unsupported_currency" errors) - this integration's account only
# supports KES.
PAYSTACK_CURRENCY=KES

# Admin
ADMIN_KEY=
